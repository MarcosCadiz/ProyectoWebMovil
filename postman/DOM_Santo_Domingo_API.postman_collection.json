{
  "info": {
    "_postman_id": "928f6c1c-c8df-4b16-96a0-dom-santo-domingo",
    "name": "DOM Santo Domingo API",
    "description": "Pruebas de backend para autenticacion, JWT, rutas protegidas, tramites y manejo de errores.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:4000/api"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "staffToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('service is healthy', () => pm.expect(pm.response.json().ok).to.eql(true));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "JWKS",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/jwks"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('returns keys array', () => pm.expect(pm.response.json().keys).to.be.an('array'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Login Usuario",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rut\": \"12.345.678-9\",\n  \"password\": \"Usuario123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('returns JWT', () => pm.expect(json.accessToken).to.be.a('string').and.not.empty);",
              "pm.test('role usuario', () => pm.expect(json.user.role).to.eql('usuario'));",
              "pm.collectionVariables.set('userToken', json.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Login Funcionario",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rut\": \"9.876.543-2\",\n  \"password\": \"Funcionario123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('returns JWT', () => pm.expect(json.accessToken).to.be.a('string').and.not.empty);",
              "pm.test('role funcionario', () => pm.expect(json.user.role).to.eql('funcionario'));",
              "pm.collectionVariables.set('staffToken', json.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Register Usuario Nuevo",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const suffix = Date.now();",
              "pm.collectionVariables.set('newRut', `${suffix}-9`);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "pm.test('returns user without password hash', () => {",
              "  const user = pm.response.json().user;",
              "  pm.expect(user.rut).to.eql(pm.collectionVariables.get('newRut'));",
              "  pm.expect(user.passwordHash).to.eql(undefined);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Usuario Postman\",\n  \"rut\": \"{{newRut}}\",\n  \"password\": \"Usuario123\",\n  \"role\": \"usuario\"\n}"
        },
        "url": "{{baseUrl}}/auth/register"
      }
    },
    {
      "name": "Usuario Actual",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}"
          }
        ],
        "url": "{{baseUrl}}/users/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('returns current user', () => pm.expect(pm.response.json().user.rut).to.eql('12.345.678-9'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Listar Tramites",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}"
          }
        ],
        "url": "{{baseUrl}}/tramites"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('returns tramites array', () => pm.expect(pm.response.json().tramites).to.be.an('array'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Crear Tramite",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tipo\": \"Permiso de Obra Menor\",\n  \"descripcion\": \"Solicitud creada desde Postman\"\n}"
        },
        "url": "{{baseUrl}}/tramites"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "pm.test('returns created tramite', () => pm.expect(pm.response.json().tramite.estado).to.eql('Nueva'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Listar Usuarios Funcionario",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{staffToken}}"
          }
        ],
        "url": "{{baseUrl}}/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('returns users array', () => pm.expect(pm.response.json().users).to.be.an('array'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Ruta Protegida Sin Token",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 401', () => pm.response.to.have.status(401));",
              "pm.test('requires auth token', () => pm.expect(pm.response.json().error).to.eql('AUTH_TOKEN_REQUIRED'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Login Invalido",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rut\": \"12.345.678-9\",\n  \"password\": \"incorrecta\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 401', () => pm.response.to.have.status(401));",
              "pm.test('invalid credentials error', () => pm.expect(pm.response.json().error).to.eql('INVALID_CREDENTIALS'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Crear Tramite Sin Tipo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"descripcion\": \"Debe fallar porque falta tipo\"\n}"
        },
        "url": "{{baseUrl}}/tramites"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 400', () => pm.response.to.have.status(400));",
              "pm.test('requires tramite type', () => pm.expect(pm.response.json().error).to.eql('TRAMITE_TYPE_REQUIRED'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
